<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:padding="16dp">

    <!-- Header Panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SMARTMARKETBOT HUB"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <TextView
            android:id="@+id/txtServiceStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SERVICE INACTIVE"
            android:textColor="#FF5555"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="#2E1B1B"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp" />
    </LinearLayout>

    <!-- Connection Mode Configuration Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1E1E1E"
        android:padding="12dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CHẾ ĐỘ KẾT NỐI (CONNECTION MODE)"
            android:textColor="#AAAAAA"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/radioGroupMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <RadioButton
                android:id="@+id/radioUsb"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cáp USB (Có dây - LiDAR+ESP32)"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:checked="true"
                android:buttonTint="#00E676"
                android:layout_marginRight="16dp" />

            <RadioButton
                android:id="@+id/radioWifi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WiFi WebSocket (Không dây - ESP32)"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:buttonTint="#00E676" />
        </RadioGroup>

        <!-- WiFi IP Configuration Section (Visible only when WiFi mode is active) -->
        <LinearLayout
            android:id="@+id/layoutWifiConfig"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Địa chỉ IP Robot:"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:layout_marginRight="12dp" />

            <EditText
                android:id="@+id/editRobotIp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="192.168.1.100"
                android:textColor="#00FF00"
                android:textSize="14sp"
                android:backgroundTint="#00E676"
                android:inputType="text"
                android:hint="Ví dụ: 192.168.4.1"
                android:padding="6dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Connection Status Cards -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp"
        android:weightSum="2">

        <!-- ESP32 Card -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="12dp"
            android:layout_marginRight="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ESP32-S3 BOARD"
                android:textColor="#AAAAAA"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtEspStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DISCONNECTED"
                android:textColor="#FFFF1744"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- LiDAR Card -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="12dp"
            android:layout_marginLeft="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YDLIDAR X3"
                android:textColor="#AAAAAA"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtLidarStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DISCONNECTED"
                android:textColor="#FFFF1744"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Control Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp"
        android:weightSum="2">

        <Button
            android:id="@+id/btnStartService"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="START HUB"
            android:backgroundTint="#00E676"
            android:textColor="#000000"
            android:layout_marginRight="8dp" />

        <Button
            android:id="@+id/btnStopService"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="STOP HUB"
            android:backgroundTint="#FF1744"
            android:textColor="#FFFFFF"
            android:layout_marginLeft="8dp" />
    </LinearLayout>

    <!-- Terminal Console Log -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#0A0A0A"
        android:padding="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SYSTEM CONSOLE LOG"
            android:textColor="#00E676"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <ScrollView
            android:id="@+id/scrollConsole"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <TextView
                android:id="@+id/txtConsole"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="[Ready] Khởi động ứng dụng, chờ kết nối...\n"
                android:textColor="#00FF00"
                android:textSize="12sp" />
        </ScrollView>
    </LinearLayout>
</LinearLayout>

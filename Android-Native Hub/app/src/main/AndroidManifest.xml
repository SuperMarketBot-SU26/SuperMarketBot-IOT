<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Quyền chạy Foreground Service cho Robot điều khiển thời gian thực (được cấp phép từ Android 9+) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    
    <!-- Loại Foreground Service cụ thể cho thiết bị phần cứng gắn ngoài (yêu cầu từ Android 14+) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    
    <!-- Yêu cầu máy chủ USB Host -->
    <uses-feature android:name="android.hardware.usb.host" />

    <application
        android:allowBackup="true"
        android:label="SmartMarketBot Hub"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light.NoActionBar">
        
        <!-- Foreground Service xử lý việc đọc luồng Serial USB liên tục cho LiDAR và ESP32 -->
        <service
            android:name="com.smartmarketbot.hub.UsbSerialService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

        <activity
            android:name="com.smartmarketbot.hub.MainActivity"
            android:exported="true"
            android:configChanges="orientation|keyboardHidden|screenSize">
            
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Tự động mở ứng dụng khi người dùng cắm USB Hub (LiDAR / ESP32-S3) vào Pad 6 -->
            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" />
            </intent-filter>
            
            <meta-data
                android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
                android:resource="@xml/device_filter" />
        </activity>
    </application>
</manifest>
